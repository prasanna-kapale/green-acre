# ============================================================
# THE GREEN ACRE — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── SERVER ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── DATABASE (Supabase PostgreSQL) ───────────────────────────
# Get these from your Supabase project > Settings > Database
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── JWT ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_random_hex_secret_here
JWT_EXPIRES_IN=8h

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://yourdomain.vercel.app,http://localhost:3000

# ── WHATSAPP NOTIFICATIONS (Twilio) ─────────────────────────
# Optional — if not set, manual WhatsApp deep links are used
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Manager's WhatsApp number (receives new booking alerts)
MANAGER_WHATSAPP=+919876543210

# ── RATE LIMITING ────────────────────────────────────────────
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# ── BOOKING ──────────────────────────────────────────────────
# Hours before a PENDING booking auto-releases
AUTO_RELEASE_HOURS=48
